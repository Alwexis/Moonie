{
  "name": "moonie",
  "version": "1.0.0",
  "description": "POC de microframework web en TypeScript",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
